+    private Bitmap loadAttachmentBitmap(Context context, LocalNotificationAttachment attachment) {
+        if (attachment == null) return null;
+        String url = attachment.getUrl();
+        if (url == null) return null;
+        try {
+            if (url.startsWith("data:image/png;base64,")) {
+                String b64 = url.substring("data:image/png;base64,".length());
+                byte[] bytes = Base64.decode(b64, Base64.DEFAULT);
+                return BitmapFactory.decodeByteArray(bytes, 0, bytes.length);
+            }
+
+            android.net.Uri uri = android.net.Uri.parse(url);
+            String scheme = uri.getScheme();
+            if (scheme == null) return null;
+            if (scheme.equals("file") || scheme.equals("content") || scheme.equals(ContentResolver.SCHEME_ANDROID_RESOURCE)) {
+                InputStream is = context.getContentResolver().openInputStream(uri);
+                if (is == null) return null;
+                try {
+                    return BitmapFactory.decodeStream(is);
+                } finally {
+                    try {
+                        is.close();
+                    } catch (Exception ex) {}
+                }
+            }
+        } catch (Exception ex) {}
+        return null;
+    }
